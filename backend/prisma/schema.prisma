generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── PROJECTS ─────────────────────────────────────────────
// Multi-project support: ERP is the first, more can be added

model Project {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  repository  String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  releases    Release[]
  pipelines   Pipeline[]
}

// ─── RELEASES ─────────────────────────────────────────────
// Every version that GitHub Actions sends to STAR

model Release {
  id             String        @id @default(uuid())
  projectId      String
  project        Project       @relation(fields: [projectId], references: [id])

  version        String
  commit         String
  message        String
  author         String
  backendImage   String
  frontendImage  String

  // Files changed (stored as JSON from GitHub API)
  filesChanged   Json?
  additions      Int           @default(0)
  deletions      Int           @default(0)

  // AI-generated content
  changelog      String?
  riskScore      Int?
  riskAnalysis   String?

  status         ReleaseStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  deployments    Deployment[]
  approvals      Approval[]
  snapshots      Snapshot[]
  scheduledDeploy ScheduledDeployment?
  notifications  Notification[]

  @@unique([projectId, version])
  @@index([projectId])
  @@index([status])
}

enum ReleaseStatus {
  PENDING
  PENDING_APPROVAL
  APPROVED
  SCHEDULED
  DEPLOYING
  DEPLOYED
  FAILED
  ROLLED_BACK
}

// ─── DEPLOYMENTS ──────────────────────────────────────────
// Every deployment attempt (a release can have multiple)

model Deployment {
  id            String           @id @default(uuid())
  releaseId     String
  release       Release          @relation(fields: [releaseId], references: [id])

  environment   Environment
  status        DeploymentStatus @default(IN_PROGRESS)
  triggeredBy   String

  // Deployment metrics
  logs          String?
  duration      Int?
  healthCheckOk Boolean?

  startedAt     DateTime         @default(now())
  completedAt   DateTime?

  @@index([releaseId])
  @@index([status])
}

enum Environment {
  BLUE
  GREEN
}

enum DeploymentStatus {
  IN_PROGRESS
  PULLING_IMAGES
  STARTING_CONTAINERS
  HEALTH_CHECKING
  SWITCHING_TRAFFIC
  SUCCESS
  FAILED
  ROLLED_BACK
}

// ─── SNAPSHOTS ────────────────────────────────────────────
// Docker image snapshots taken before each deployment

model Snapshot {
  id              String   @id @default(uuid())
  releaseId       String
  release         Release  @relation(fields: [releaseId], references: [id])

  backendTag      String
  frontendTag     String
  environment     Environment
  description     String?

  createdAt       DateTime @default(now())

  @@index([releaseId])
}

// ─── SCHEDULED DEPLOYMENTS ────────────────────────────────
// Deployments queued for a specific time

model ScheduledDeployment {
  id            String   @id @default(uuid())
  releaseId     String   @unique
  release       Release  @relation(fields: [releaseId], references: [id])

  scheduledFor  DateTime
  timezone      String   @default("Africa/Tunis")
  reason        String?

  jobId         String?
  executed      Boolean  @default(false)
  cancelledAt   DateTime?

  createdAt     DateTime @default(now())

  @@index([scheduledFor])
}

// ─── APPROVALS ────────────────────────────────────────────
// Deployment approval gate

model Approval {
  id          String         @id @default(uuid())
  releaseId   String
  release     Release        @relation(fields: [releaseId], references: [id])

  approvedBy  String
  status      ApprovalStatus @default(PENDING)
  comment     String?

  createdAt   DateTime       @default(now())

  @@index([releaseId])
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── NOTIFICATIONS ────────────────────────────────────────
// Email notification log

model Notification {
  id          String             @id @default(uuid())
  releaseId   String?
  release     Release?           @relation(fields: [releaseId], references: [id])

  type        NotificationType
  recipient   String
  subject     String
  body        String?
  status      NotificationStatus @default(PENDING)
  sentAt      DateTime?
  error       String?

  createdAt   DateTime           @default(now())

  @@index([releaseId])
}

enum NotificationType {
  DEPLOYMENT_SUCCESS
  DEPLOYMENT_FAILED
  APPROVAL_REQUIRED
  SCHEDULED_REMINDER
  ROLLBACK_COMPLETED
  HEALTH_CHECK_FAILED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

// ─── PIPELINES ────────────────────────────────────────────
// CI/CD pipeline configuration per project

model Pipeline {
  id            String   @id @default(uuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id])

  name          String
  branch        String   @default("main")
  webhookUrl    String?
  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
}

// ─── SYSTEM CONFIG ────────────────────────────────────────
// Key-value store for runtime config

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// ─── AI ANALYSIS LOG ──────────────────────────────────────
// Track all AI interactions for monitoring

model AiAnalysis {
  id          String       @id @default(uuid())
  type        AiAnalysisType
  input       String
  output      String
  model       String       @default("claude-sonnet-4-20250514")
  tokens      Int?
  duration    Int?

  createdAt   DateTime     @default(now())

  @@index([type])
}

enum AiAnalysisType {
  RISK_ANALYSIS
  LOG_ANALYSIS
  CHANGELOG_GENERATION
  ANOMALY_DETECTION
  LOG_QUERY
}

// ─── DEPLOYMENT METRICS ───────────────────────────────────
// Time-series data for anomaly detection

model DeploymentMetric {
  id              String   @id @default(uuid())
  deploymentId    String
  metricType      String
  value           Float
  timestamp       DateTime @default(now())

  @@index([deploymentId])
  @@index([metricType, timestamp])
}
